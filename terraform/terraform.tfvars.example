# ─── Proxmox ──────────────────────────────────────────────────────────────────

proxmox_endpoint  = "https://192.168.0.100:8006"
proxmox_api_token = "terraform@pve!atlas=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_node      = "proxmox"

# ─── Storage & Networking ─────────────────────────────────────────────────────

disk_storage   = "CRUCIAL_SSD_512GB"
iso_storage    = "local"
network_bridge = "vmbr0"
vlan_id        = 20

# ─── Talos & Cluster ──────────────────────────────────────────────────────────

talos_version      = "v1.12.6"
talos_schematic_id = "ce4c980550dd2ab1b17bbf2b08801c7eb59418eafe8f279833297925d67c7515"
cluster_name       = "atlas"

# ─── Network (VLAN 20) ────────────────────────────────────────────────────────

subnet_prefix    = 24
gateway          = "192.168.20.1"
dns_server       = "192.168.0.101"
control_plane_ip = "192.168.20.10"

# One IP per worker — add entries here to scale out
worker_ips = ["192.168.20.11"]

# ─── VM Sizing ────────────────────────────────────────────────────────────────

control_plane_cpu       = 2
control_plane_memory    = 4096
control_plane_disk_size = 20

worker_cpu       = 2
worker_memory    = 6144
worker_disk_size = 75
